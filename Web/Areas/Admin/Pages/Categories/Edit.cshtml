@page "{id:guid}"
@model Web.Areas.Admin.Pages.Categories.EditModel
@{
    ViewData["Title"] = "Edit Category";
}
<section class="bg-white rounded-3 shadow-sm p-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h1 class="display-6 mb-1">Edit Category</h1>
            <p class="text-muted mb-0">Update category details.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-page="/Categories/Index" asp-area="Admin">Back</a>
    </div>
    <form method="post" class="mt-3">
        <input type="hidden" asp-for="Category.Id" />
        <div class="mb-3">
            <label class="form-label">Name</label>
            <input class="form-control" asp-for="Category.Name" />
        </div>
        <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea class="form-control" asp-for="Category.Description" rows="3"></textarea>
        </div>

        <div class="mb-3">
            <label class="form-label">Variant Types</label>
            <p class="text-muted small mb-2">Define the variant dimensions for products in this category (e.g., Size, Color, Material).</p>
            <div id="variantTypesList" class="d-flex flex-column gap-2">
            </div>
            <button type="button" class="btn btn-outline-primary btn-sm mt-2" id="addVariantTypeBtn">
                <i class="bi bi-plus-circle"></i> Add Variant Type
            </button>
        </div>

        <div class="d-flex gap-2">
            <button class="btn btn-success" type="submit">Save</button>
            <a class="btn btn-outline-secondary" asp-page="/Categories/Index" asp-area="Admin">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <script>
        (function () {
            const list = document.getElementById("variantTypesList");
            const addBtn = document.getElementById("addVariantTypeBtn");
            let index = 0;

            function addRow(value) {
                const row = document.createElement("div");
                row.className = "d-flex gap-2 align-items-center";
                row.innerHTML = `
                    <input type="text" name="VariantTypeNames[${index}]" value="${value || ''}" class="form-control" placeholder="e.g., Size, Color" required />
                    <button type="button" class="btn btn-outline-danger btn-sm" onclick="this.parentElement.remove()">Remove</button>
                `;
                list.appendChild(row);
                index++;
            }

            addBtn.addEventListener("click", () => addRow(""));

            // Load existing variant types
            const existing = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.VariantTypeNames));
            existing.forEach(name => addRow(name));
        })();
    </script>
}
