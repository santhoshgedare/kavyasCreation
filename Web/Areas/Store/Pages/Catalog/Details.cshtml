@page "{id:guid}"
@model Web.Areas.Store.Pages.Catalog.DetailsModel
@{
    ViewData["Title"] = Model.Product?.Name ?? "Product";
}

@section Scripts {
    <script>
        (function () {
            // Zoom logic
            const zoomContainers = document.querySelectorAll("[data-zoom]");
            zoomContainers.forEach(container => {
                const img = container.querySelector(".product-zoom-image");
                if (!img) return;

                container.addEventListener("mousemove", (event) => {
                    const rect = container.getBoundingClientRect();
                    const x = ((event.clientX - rect.left) / rect.width) * 100;
                    const y = ((event.clientY - rect.top) / rect.height) * 100;
                    img.style.transformOrigin = `${x}% ${y}%`;
                });

                container.addEventListener("mouseenter", () => { img.classList.add("zoomed"); });
                container.addEventListener("mouseleave", () => {
                    img.classList.remove("zoomed");
                    img.style.transformOrigin = "center center";
                });
            });

            // Variant selection logic
            const variantSelector = document.getElementById("variantSelector");
            if (!variantSelector) return;

            const variants = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Product!.Variants.Select(v => new {
                    id = v.Id,
                    price = v.Price,
                    stock = v.Stock,
                    options = v.Options.ToDictionary(o => o.CategoryVariantType?.Name ?? "", o => o.Value),
                    images = v.Images.OrderBy(i => i.SortOrder).Select(i => i.Url).ToList()
                })));

            const selectedOptions = {};
            const displayPrice = document.getElementById("displayPrice");
            const variantIdInput = document.getElementById("selectedVariantId");
            const addToCartBtn = document.getElementById("addToCartBtn");
            const stockInfo = document.getElementById("variantStockInfo");
            const carousel = document.getElementById("productCarousel");
            const carouselInner = carousel?.querySelector(".carousel-inner");
            const thumbStrip = document.getElementById("thumbStrip");

            // Store the general (non-variant) product images
            const generalImages = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Product!.Images.Where(i => i.ProductVariantId == null).OrderBy(i => i.SortOrder).Select(i => i.Url).ToList()));

            function rebuildCarousel(imageUrls) {
                if (!carouselInner) return;
                const productName = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Product.Name));
                const urls = imageUrls.length > 0 ? imageUrls : ["/uploads/products/placeholder.svg"];
                carouselInner.innerHTML = "";
                urls.forEach((url, i) => {
                    const item = document.createElement("div");
                    item.className = "carousel-item" + (i === 0 ? " active" : "");
                    item.innerHTML = `<div class="product-zoom" data-zoom><img src="${url}" class="d-block w-100 product-carousel-img product-zoom-image" alt="${productName}" /></div>`;
                    carouselInner.appendChild(item);
                });
                // Rebuild thumbnails
                if (thumbStrip) {
                    thumbStrip.innerHTML = "";
                    urls.forEach((url, i) => {
                        const btn = document.createElement("button");
                        btn.className = "border rounded p-1 bg-white product-thumb";
                        btn.type = "button";
                        btn.setAttribute("data-bs-target", "#productCarousel");
                        btn.setAttribute("data-bs-slide-to", i);
                        btn.setAttribute("aria-label", `Slide ${i + 1}`);
                        btn.innerHTML = `<img src="${url}" class="rounded product-thumb-img" alt="${productName}" />`;
                        thumbStrip.appendChild(btn);
                    });
                }
                // Re-init Bootstrap carousel
                const bsCarousel = bootstrap.Carousel.getOrCreateInstance(carousel);
                bsCarousel.to(0);
                // Re-attach zoom
                carouselInner.querySelectorAll("[data-zoom]").forEach(container => {
                    const img = container.querySelector(".product-zoom-image");
                    if (!img) return;
                    container.addEventListener("mousemove", (event) => {
                        const rect = container.getBoundingClientRect();
                        const x = ((event.clientX - rect.left) / rect.width) * 100;
                        const y = ((event.clientY - rect.top) / rect.height) * 100;
                        img.style.transformOrigin = `${x}% ${y}%`;
                    });
                    container.addEventListener("mouseenter", () => { img.classList.add("zoomed"); });
                    container.addEventListener("mouseleave", () => { img.classList.remove("zoomed"); img.style.transformOrigin = "center center"; });
                });
            }

            document.querySelectorAll(".variant-option-btn").forEach(btn => {
                btn.addEventListener("click", () => {
                    const typeName = btn.dataset.typeName;
                    const value = btn.dataset.value;

                    if (btn.disabled) return;

                    // Toggle selection
                    if (selectedOptions[typeName] === value) {
                        delete selectedOptions[typeName];
                        btn.classList.remove("active", "btn-primary");
                        btn.classList.add("btn-outline-secondary");
                    } else {
                        selectedOptions[typeName] = value;
                        // Deselect siblings
                        btn.closest(".variant-type-group").querySelectorAll(".variant-option-btn").forEach(b => {
                            b.classList.remove("active", "btn-primary");
                            b.classList.add("btn-outline-secondary");
                        });
                        btn.classList.remove("btn-outline-secondary");
                        btn.classList.add("active", "btn-primary");
                    }

                    updateAvailability();
                    updateSelection();
                });
            });

            // Disable option buttons that have no valid variant combination
            // with the current selection.
            function updateAvailability() {
                document.querySelectorAll(".variant-type-group").forEach(group => {
                    const groupType = group.dataset.typeName;
                    group.querySelectorAll(".variant-option-btn").forEach(btn => {
                        const btnType = btn.dataset.typeName;
                        const btnValue = btn.dataset.value;

                        // Build a hypothetical selection: current selections + this button
                        const hypothetical = { ...selectedOptions, [btnType]: btnValue };

                        // Check if ANY variant matches all entries in the hypothetical selection
                        const hasMatch = variants.some(v =>
                            Object.entries(hypothetical).every(([key, val]) => v.options[key] === val)
                        );

                        if (hasMatch) {
                            btn.disabled = false;
                            btn.classList.remove("opacity-50");
                        } else {
                            btn.disabled = true;
                            btn.classList.add("opacity-50");
                            // If this button was selected but is now impossible, deselect it
                            if (selectedOptions[btnType] === btnValue) {
                                delete selectedOptions[btnType];
                                btn.classList.remove("active", "btn-primary");
                                btn.classList.add("btn-outline-secondary");
                            }
                        }
                    });
                });
            }

            // Run once on load to set initial availability
            updateAvailability();

            function updateSelection() {
                const match = variants.find(v => {
                    return Object.keys(selectedOptions).length > 0 &&
                        Object.entries(selectedOptions).every(([key, val]) => v.options[key] === val) &&
                        Object.keys(v.options).length === Object.keys(selectedOptions).length;
                });

                if (match) {
                    displayPrice.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(match.price);
                    variantIdInput.value = match.id;
                    addToCartBtn.disabled = match.stock <= 0;
                    addToCartBtn.innerHTML = match.stock > 0
                        ? '<i class="bi bi-cart-plus"></i> Add to Cart'
                        : '<i class="bi bi-x-circle"></i> Out of Stock';
                    stockInfo.innerHTML = match.stock > 0
                        ? `<span class="badge bg-success">${match.stock} in stock</span>`
                        : '<span class="badge bg-danger">Out of stock</span>';
                    // Show variant images if available, otherwise keep general
                    if (match.images && match.images.length > 0) {
                        rebuildCarousel(match.images);
                    } else {
                        rebuildCarousel(generalImages);
                    }
                } else {
                    const minPrice = Math.min(...variants.map(v => v.price));
                    displayPrice.textContent = "From " + new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(minPrice);
                    variantIdInput.value = "";
                    addToCartBtn.disabled = true;
                    addToCartBtn.innerHTML = '<i class="bi bi-cart-plus"></i> Select options to add to cart';
                    stockInfo.innerHTML = "";
                    rebuildCarousel(generalImages);
                }
            }
        })();
    </script>
}
@if (Model.Product is null)
{
    <div class="alert alert-warning">Product not found.</div>
}
else
{
    <section class="bg-white rounded-3 shadow-sm p-4">
        <div class="row g-4">
            <div class="col-lg-6">
                <div id="productCarousel" class="carousel slide shadow-sm product-carousel" data-bs-ride="carousel">
                    <div class="carousel-inner rounded product-carousel-inner">
                        @{
                            var generalImgs = Model.Product.Images.Where(i => i.ProductVariantId == null).ToList();
                            var images = generalImgs.Any()
                                ? generalImgs
                                : new List<Core.Entities.ProductImage> { new() { Url = "/uploads/products/placeholder.svg" } };
                            var first = true;
                        }
                        @foreach (var image in images)
                        {
                            <div class="carousel-item @(first ? "active" : "")">
                                <div class="product-zoom" data-zoom>
                                    <img src="@image.Url" class="d-block w-100 product-carousel-img product-zoom-image" alt="@Model.Product.Name" />
                                </div>
                            </div>
                            first = false;
                        }
                    </div>
                    <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
                        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Previous</span>
                    </button>
                    <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
                        <span class="carousel-control-next-icon" aria-hidden="true"></span>
                        <span class="visually-hidden">Next</span>
                    </button>
                </div>

                @if (Model.Product.Images.Where(i => i.ProductVariantId == null).Any())
                {
                    <div id="thumbStrip" class="d-flex flex-wrap gap-2 mt-3">
                        @{ var generalThumbs = Model.Product.Images.Where(i => i.ProductVariantId == null).ToList(); }
                        @for (var i = 0; i < generalThumbs.Count; i++)
                        {
                            var image = generalThumbs[i];
                            <button class="border rounded p-1 bg-white product-thumb" type="button" data-bs-target="#productCarousel" data-bs-slide-to="@i" aria-label="Slide @(i + 1)">
                                <img src="@image.Url" class="rounded product-thumb-img" alt="@Model.Product.Name" />
                            </button>
                        }
                    </div>
                }
                else
                {
                    <div id="thumbStrip" class="d-flex flex-wrap gap-2 mt-3"></div>
                }
            </div>
            <div class="col-lg-6">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h1 class="display-6 mb-1">@Model.Product.Name</h1>
                        <div class="text-muted">@Model.Product.Category?.Name</div>
                    </div>
                    <span class="badge bg-success">In stock</span>
                </div>
                <p class="text-muted mt-3">@Model.Product.Description</p>

                @if (Model.Product.Variants.Any())
                {
                    <h3 class="fw-bold" id="displayPrice">From @Model.Product.Variants.Min(v => v.Price).ToString("C")</h3>

                    <!-- Variant Selector -->
                    <div class="mt-3" id="variantSelector">
                        @foreach (var vt in Model.VariantTypes)
                        {
                            <div class="mb-2">
                                <label class="form-label fw-semibold">@vt.Name</label>
                                <div class="d-flex flex-wrap gap-2 variant-type-group" data-type-name="@vt.Name">
                                    @{
                                        var distinctValues = Model.Product.Variants
                                            .SelectMany(v => v.Options.Where(o => o.CategoryVariantTypeId == vt.Id))
                                            .Select(o => o.Value)
                                            .Distinct()
                                            .ToList();
                                    }
                                    @foreach (var val in distinctValues)
                                    {
                                        <button type="button" class="btn btn-outline-secondary btn-sm variant-option-btn"
                                                data-type-name="@vt.Name" data-value="@val">
                                            @val
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div id="variantStockInfo" class="mt-2"></div>

                    <div class="mt-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form method="post" asp-page-handler="Add" class="d-inline" id="addToCartForm">
                                <input type="hidden" name="productId" value="@Model.Product.Id" />
                                <input type="hidden" name="variantId" id="selectedVariantId" value="" />
                                <button class="btn btn-primary" type="submit" id="addToCartBtn" disabled>
                                    <i class="bi bi-cart-plus"></i> Select options to add to cart
                                </button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Login"
                               asp-route-returnUrl="@($"/Store/Catalog/Details/{Model.Product.Id}")">
                                <i class="bi bi-person-circle"></i> Login to Add to Cart
                            </a>
                        }
                        <a class="btn btn-outline-secondary" asp-page="/Catalog/Index" asp-area="Store">
                            <i class="bi bi-arrow-left"></i> Back to Catalog
                        </a>
                    </div>
                }
                else
                {
                    <h3 class="fw-bold">@Model.Product.Price.ToString("C")</h3>

                    <div class="mt-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <form method="post" asp-page-handler="Add" class="d-inline">
                                <input type="hidden" name="productId" value="@Model.Product.Id" />
                                <button class="btn btn-primary" type="submit">
                                    <i class="bi bi-cart-plus"></i> Add to Cart
                                </button>
                            </form>
                        }
                        else
                        {
                            <a class="btn btn-primary" asp-area="Identity" asp-page="/Account/Login"
                               asp-route-returnUrl="@($"/Store/Catalog/Details/{Model.Product.Id}")">
                                <i class="bi bi-person-circle"></i> Login to Add to Cart
                            </a>
                        }
                        <a class="btn btn-outline-secondary" asp-page="/Catalog/Index" asp-area="Store">
                            <i class="bi bi-arrow-left"></i> Back to Catalog
                        </a>
                    </div>
                }

                @if (Model.Product.Specifications.Any())
                {
                    <div class="mt-4">
                        <h5>Specifications</h5>
                        <ul class="list-group list-group-flush">
                            @foreach (var spec in Model.Product.Specifications)
                            {
                                <li class="list-group-item d-flex justify-content-between">
                                    <span>@spec.Key</span>
                                    <span class="text-muted">@spec.Value</span>
                                </li>
                            }
                        </ul>
                    </div>
                }
            </div>
        </div>
    </section>
}
